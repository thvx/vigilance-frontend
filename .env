# ─────────────────────────────────────────────────────────────
# Frontend - Backend Connection Configuration
# ─────────────────────────────────────────────────────────────
# 
# Configuration for connecting the frontend to the Docker backend.
# The backend runs in Docker with Nginx acting as a reverse proxy.
#
# Development Setup:
# - Frontend dev server: http://localhost:5173 (Vite)
# - Backend API: http://localhost/api (Nginx reverse proxy)
# - Nginx Port: 80 (default HTTP)
# 
# The Vite dev server (vite.config.ts) proxies requests:
# - /api → http://localhost (Nginx) → :8000 (FastAPI)
# - /ws → ws://localhost (Nginx) → :8000 (WebSocket)
# - /hls → http://localhost:8888 (MediaMTX for live streams)
#

# Backend REST API base URL
# All REST endpoints will be appended to this URL
# Frontend makes requests like: http://localhost/api/cameras, etc.
VITE_API_BASE_URL=http://localhost/api

# Backend WebSocket URL for real-time events
# Used for live alerts, camera status updates, frame metrics
# Connection path: ws://localhost/ws or wss:// for HTTPS
VITE_WS_URL=ws://localhost/ws

# Optional: Sentry DSN for error tracking
# Leave empty to disable
VITE_SENTRY_DSN=

